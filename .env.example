ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
PORT=3001
# Comma-separated list of allowed frontend origins for CORS
CLIENT_ORIGIN=http://localhost:5173
# Public app URL used for provider metadata and OAuth redirects
APP_URL=http://localhost:5173
# Public server URL (used to build the OAuth callback URL)
SERVER_URL=http://localhost:3001

# MongoDB connection string (required for auth and history features)
MONGODB_URI=

# Google OAuth credentials (create at console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Secret used to sign JWTs
# REQUIRED in production: generate with `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`
# Must NOT be the placeholder value — the server will refuse to start in production if it is.
JWT_SECRET=

# Donated API key pool (required if you use /api/key-pool or fallback queue)
# Generate both with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
KEY_POOL_ENCRYPTION_SECRET=
KEY_POOL_FINGERPRINT_SECRET=
